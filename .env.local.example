# ──────────────────────────────────────────────
# 게임 리뷰 블로그 환경 변수 예시 파일
# 실제 사용 시 이 파일을 .env.local로 복사 후 값 입력
# .env.local은 .gitignore에 포함되어 있어 Git에 커밋되지 않음
# ──────────────────────────────────────────────

# Notion Integration 시크릿 키
# Notion → Settings → Connections → Develop or manage integrations에서 발급
NOTION_API_KEY=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 게임 리뷰 Notion 데이터베이스 ID
# Notion 데이터베이스 URL의 32자리 UUID (하이픈 없는 형태)
# 예: https://notion.so/{workspace}/{database_id}?v=...
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 배포 사이트 URL (sitemap, robots.txt 생성에 사용)
# Vercel 배포 시 실제 URL로 변경 (예: https://your-app.vercel.app)
NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app
